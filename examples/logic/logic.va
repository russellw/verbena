IF (1 = 1 AND 2 = 2) THEN PRINT "PASS" ELSE PRINT "FAIL"
IF (1 = 1 OR 2 = 3) THEN PRINT "PASS" ELSE PRINT "FAIL"
IF NOT (1 = 2) THEN PRINT "PASS" ELSE PRINT "FAIL"
IF (1 = 1 AND (2 = 3 OR 3 = 3)) THEN PRINT "PASS" ELSE PRINT "FAIL"
IF (1 = 1 AND NOT (2 = 2)) THEN PRINT "PASS" ELSE PRINT "FAIL"
IF ((1 = 1 AND 2 = 2) OR (3 = 4 AND 5 = 6)) THEN PRINT "PASS" ELSE PRINT "FAIL"
IF NOT ((1 = 2 OR 3 = 3) AND (4 = 5)) THEN PRINT "PASS" ELSE PRINT "FAIL"
IF ((1 = 1 AND 2 = 2) OR NOT (3 = 4)) AND (5 = 5 OR 6 = 7) THEN PRINT "PASS" ELSE PRINT "FAIL"
IF (1 = 2 OR 3 = 4) AND NOT (5 = 5) THEN PRINT "PASS" ELSE PRINT "FAIL"
