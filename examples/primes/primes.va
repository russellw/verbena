10 REM PROGRAM TO PRINT ALL PRIME NUMBERS LESS THAN 100
20 PRINT "PRIME NUMBERS LESS THAN 100:"
30 PRINT 2
40 FOR N = 3 TO 99 STEP 2
50   PRIME = 1
60   FOR I = 3 TO SQR(N)
70     IF N/I = INT(N/I) THEN PRIME = 0: I = N
80   NEXT I
90   IF PRIME = 1 THEN PRINT N;
100 NEXT N
110 PRINT
120 PRINT "END OF PROGRAM"
130 END
