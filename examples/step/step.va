10 REM DEMONSTRATION OF FOR LOOP WITH STEP
20 REM THIS PROGRAM COUNTS FROM 1 TO 20 BY 3
30 PRINT "COUNTING FROM 1 TO 20 BY STEP OF 3:"
40 PRINT
50 FOR I = 1 TO 20 STEP 3
60   PRINT "COUNTER VALUE: "; I
70 NEXT I
80 PRINT
90 PRINT "PROGRAM COMPLETE"
100 REM DEMONSTRATION OF COUNTING BACKWARDS
110 PRINT
120 PRINT "COUNTING BACKWARDS FROM 10 TO 1 BY STEP OF -1:"
130 PRINT
140 FOR J = 10 TO 1 STEP -1
150   PRINT "COUNTER VALUE: "; J
160 NEXT J
170 PRINT
180 PRINT "END OF DEMONSTRATION"
190 END
